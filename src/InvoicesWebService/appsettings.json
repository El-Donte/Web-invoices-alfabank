{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "AggregationGroup": {
      "BootstrapServers": "kafka:9092",
      "Topic": "aggregationgroup.ready.event",
      "GroupId": "invoice-web-service-v1",
      "BatchSize": 0,
      "FlushIntervalMs" : 0
    },
    "Abs": {
      "BootstrapServers": "kafka:9092",
      "Topic": "abs.message",
      "GroupId": "invoice-web-service-v1",
      "BatchSize": 0,
      "FlushIntervalMs" : 0
    }
  }
}
