{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "AggregationGroup": {
      "BootstrapServers": "kafka:9092",
      "Topic": "abs.aggregation_ready",
      "GroupId": "invoice-web-service-v1",
      "BatchSize": 0,
      "FlushIntervalMs" : 0
    },
    "AbsMessage": {
      "BootstrapServers": "kafka:9092",
      "Topic": "abs.abs.message",
      "GroupId": "invoice-web-service-v1",
      "BatchSize": 0,
      "FlushIntervalMs" : 0
    }
  }
}
