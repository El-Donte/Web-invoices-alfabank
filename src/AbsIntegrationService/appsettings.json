{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "AggregationGroup": {
      "BootstrapServers": "kafka:9092",
      "Topic": "aggregationgroup.ready.event",
      "GroupId": "abs-ingestion-service-v1",
      "BatchSize": 0,
      "FlushIntervalMs" : 0
    },
    "Abs": {
      "BootstrapServers": "kafka:9092",
      "Topic": "abs.message",
      "GroupId": "abs-ingestion-service-v1",
      "BatchSize": 50000,
      "FlushIntervalMs": 10
    }
  },
  "AggregationWorker": {
    "IntervalSeconds": 2,
    "BatchSize": 15000,
    "MinimumTransactionsForReady": 1,
    "TimeoutMinutes": 1,
    "EventBatchSize": 50000,
    "EventFlushIntervalMs": 100,
    "MaxParallelGroups": 24
  }
}
